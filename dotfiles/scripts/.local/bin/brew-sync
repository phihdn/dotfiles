#!/usr/bin/env bash

# brew-sync: Synchronize Homebrew packages with Brewfile
# This script ensures only packages listed in Brewfile are installed

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Find Brewfile
BREWFILE=""
if [[ -f "./Brewfile" ]]; then
    BREWFILE="./Brewfile"
elif [[ -f "$HOME/dotfiles/Brewfile" ]]; then
    BREWFILE="$HOME/dotfiles/Brewfile"
elif [[ -f "$HOME/.config/Brewfile" ]]; then
    BREWFILE="$HOME/.config/Brewfile"
else
    echo -e "${RED}Error: Brewfile not found in current directory, ~/dotfiles, or ~/.config${NC}"
    exit 1
fi

echo -e "${BLUE}🍺 Homebrew Package Synchronization${NC}"
echo -e "${BLUE}Using Brewfile: ${BREWFILE}${NC}"
echo ""

# Function to show what will be removed
show_cleanup_preview() {
    echo -e "${YELLOW}📋 Packages that will be removed (not in Brewfile):${NC}"
    if brew bundle cleanup --file="$BREWFILE" 2>/dev/null | grep -q "Would uninstall"; then
        brew bundle cleanup --file="$BREWFILE" 2>/dev/null | grep "Would uninstall" | sed 's/Would uninstall /  - /'
        return 0
    else
        echo -e "${GREEN}  ✅ No packages to remove - all installed packages are in Brewfile${NC}"
        return 1
    fi
}

# Function to install packages from Brewfile
install_packages() {
    echo -e "${BLUE}📦 Installing packages from Brewfile...${NC}"
    brew bundle --file="$BREWFILE"
}

# Function to cleanup packages not in Brewfile
cleanup_packages() {
    echo -e "${BLUE}🧹 Removing packages not listed in Brewfile...${NC}"
    brew bundle cleanup --file="$BREWFILE" --force
}

# Main execution
case "${1:-sync}" in
    "preview"|"--preview"|"-p")
        echo -e "${BLUE}🔍 Preview mode - showing what would be changed${NC}"
        echo ""
        show_cleanup_preview
        ;;
    "install"|"--install"|"-i")
        install_packages
        ;;
    "cleanup"|"--cleanup"|"-c")
        if show_cleanup_preview; then
            echo ""
            read -p "Do you want to proceed with cleanup? (y/N): " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                cleanup_packages
                echo -e "${GREEN}✅ Cleanup completed${NC}"
            else
                echo -e "${YELLOW}⚠️  Cleanup cancelled${NC}"
            fi
        fi
        ;;
    "sync"|"--sync"|"-s"|"")
        install_packages
        echo ""
        if show_cleanup_preview; then
            echo ""
            read -p "Do you want to proceed with cleanup? (y/N): " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                cleanup_packages
                echo -e "${GREEN}✅ Synchronization completed${NC}"
            else
                echo -e "${YELLOW}⚠️  Only installation completed, cleanup skipped${NC}"
            fi
        else
            echo -e "${GREEN}✅ Synchronization completed${NC}"
        fi
        ;;
    "force"|"--force"|"-f")
        install_packages
        echo ""
        cleanup_packages
        echo -e "${GREEN}✅ Force synchronization completed${NC}"
        ;;
    "help"|"--help"|"-h")
        echo "Usage: brew-sync [COMMAND]"
        echo ""
        echo "Commands:"
        echo "  sync, -s     Install from Brewfile and prompt for cleanup (default)"
        echo "  preview, -p  Show what packages would be removed"
        echo "  install, -i  Only install packages from Brewfile"
        echo "  cleanup, -c  Only cleanup packages not in Brewfile"
        echo "  force, -f    Install and cleanup without prompting"
        echo "  help, -h     Show this help message"
        echo ""
        echo "Examples:"
        echo "  brew-sync           # Install and prompt for cleanup"
        echo "  brew-sync preview   # See what would be removed"
        echo "  brew-sync force     # Install and cleanup automatically"
        ;;
    *)
        echo -e "${RED}Error: Unknown command '$1'${NC}"
        echo "Use 'brew-sync help' for usage information"
        exit 1
        ;;
esac
