#!/usr/bin/env fish
# Translates program names to icons, so we an use them in our tmux config.
# Based on https://github.com/caarlos0/icons
switch $argv[1]
    case ack fd find fzf grep rg
        echo пҗў
    case atop htop top
        echo пҲҖ
    case bash fish zsh sh ash
        echo оһ•
    case bat cat
        echo пҶ°
    case clx
        echo оҷӮ
    case cp duplicate
        echo пғ…
    case mv
        echo у°ү’
    case curl http pint lynx wget w3m
        echo п’„
    case docker docker-compose podman
        echo пҢҲ
    case lf ls nnn ranger lsd
        echo пҗ“
    case elixir mix
        echo оҳӯ
    case gh gh-dash
        echo оңҲ
    case git lazygit tig
        echo оңҘ
    case glow
        echo п’Ҡ
    case go goreleaser
        echo оҳ§
    case kubectl k9s
        echo о қ
    case java mvn
        echo оү–
    case less more
        echo пҖ¶
    case lua
        echo оҳ 
    case man
        echo пҖӯ
    case nano pico
        echo п…ң
    case node npm yarn
        echo оһҒ
    case 'nix*'
        echo уұ„…
    case vim vi
        echo оҳ«
    case nvim
        echo пҚҜ
    case python pip
        echo оңј
    case rm
        echo оӘҒ
    case rsync
        echo п‘Ә
    case ruby irb
        echo оһ‘
    case scp ssh
        echo у°ЈҖ
    case sleep
        echo пү’
    case sudo
        echo п„Ә
    case tail
        echo п“ӯ
    case task make
        echo оҷі
    case tmux
        echo оҜҲ
    case claude
        echo у°ҡ©
    case youtube-dl
        echo п…Ә
end
