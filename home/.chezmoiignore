# Patterns of target paths chezmoi should never manage.
# Syntax mirrors .gitignore (patterns are relative to $HOME).

.DS_Store

# k9s runtime state (per-machine, not tracked)
.config/k9s/benchmarks
.config/k9s/clusters
.config/k9s/screen-dumps

# zsh plugins are cloned at runtime by the plugin manager
.config/zsh/plugins

# tmux plugins are cloned at runtime by tpm
.config/tmux/plugins
